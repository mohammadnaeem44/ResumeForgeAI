@page
@model ResumeForgeAI.Pages.RegisterModel
@{
    ViewData["Title"] = "Create an Account";
}

<div class="min-h-screen bg-gray-50 flex flex-col justify-center py-12 sm:px-6 lg:px-8">
    <div class="sm:mx-auto sm:w-full sm:max-w-md">
        <div class="text-center text-3xl font-bold tracking-tight text-[#1e3a5f]">
            <i class="fa-solid fa-file-signature text-[#f59e0b] mr-2"></i>ResumeForge AI
        </div>
        <h2 class="mt-6 text-center text-3xl font-extrabold text-gray-900">Create a new account</h2>
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="mt-4 bg-red-50 border-l-4 border-red-500 p-4 text-red-700">
                <p>@Model.ErrorMessage</p>
            </div>
        }
    </div>

    <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
        <div class="bg-white py-8 px-4 shadow sm:rounded-lg sm:px-10">
            <form method="post" class="space-y-6">
                <div>
                    <label for="name" class="block text-sm font-medium text-gray-700">Full Name</label>
                    <div class="mt-1">
                        <input id="name" name="name" type="text" required class="appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-[#f59e0b] sm:text-sm">
                    </div>
                </div>

                <div>
                    <label for="email" class="block text-sm font-medium text-gray-700">Email address</label>
                    <div class="mt-1">
                        <input id="email" name="email" type="email" required class="appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-[#f59e0b] sm:text-sm">
                    </div>
                </div>

                <div>
                    <label for="university" class="block text-sm font-medium text-gray-700">University / Company</label>
                    <div class="mt-1">
                        <input id="university" name="university" type="text" class="appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-[#f59e0b] sm:text-sm">
                    </div>
                </div>

                <div>
                    <label for="password" class="block text-sm font-medium text-gray-700">Password</label>
                    <div class="mt-1">
                        <input id="password" name="password" type="password" required class="appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-[#f59e0b] sm:text-sm">
                    </div>
                </div>

                <div>
                    <button type="submit" class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-[#1e3a5f] bg-[#f59e0b] hover:bg-yellow-500 focus:outline-none">
                        Register
                    </button>
                    <!-- API: POST /api/auth/register -->
                </div>
            </form>
            <div class="mt-6 text-center">
                <p class="text-sm text-gray-600">Already registered? <a href="/Login" class="font-medium text-[#1e3a5f] hover:text-[#f59e0b]">Sign in</a></p>
            </div>
        </div>
    </div>
</div>

