@page
@{
    ViewData["Title"] = "Settings & Profile";
}

<div class="flex h-screen bg-gray-50">
    <!-- Sidebar -->
    <aside class="w-64 bg-[#1e3a5f] text-white flex flex-col shadow-lg">
        <div class="h-16 flex items-center px-6 border-b border-gray-700">
            <h1 class="text-xl font-bold text-[#f59e0b]"><i class="fa-solid fa-file-signature mr-2"></i>ResumeForge</h1>
        </div>
        <nav class="flex-1 px-4 py-6 space-y-2">
            <a href="/Dashboard" class="flex items-center px-4 py-3 text-gray-300 hover:bg-white hover:bg-opacity-5 rounded-lg transition"><i class="fa-solid fa-house mb-1 mr-3 w-5"></i> Dashboard</a>
            <a href="/ResumeBuilder" class="flex items-center px-4 py-3 text-gray-300 hover:bg-white hover:bg-opacity-5 rounded-lg transition"><i class="fa-solid fa-file-lines mb-1 mr-3 w-5"></i> Resume Builder</a>
            <a href="/CoverLetter" class="flex items-center px-4 py-3 text-gray-300 hover:bg-white hover:bg-opacity-5 rounded-lg transition"><i class="fa-solid fa-envelope mb-1 mr-3 w-5"></i> Cover Letters</a>
            <a href="/AtsChecker" class="flex items-center px-4 py-3 text-gray-300 hover:bg-white hover:bg-opacity-5 rounded-lg transition"><i class="fa-solid fa-chart-line mb-1 mr-3 w-5"></i> ATS Checker</a>
            <a href="/Templates" class="flex items-center px-4 py-3 text-gray-300 hover:bg-white hover:bg-opacity-5 rounded-lg transition"><i class="fa-solid fa-layer-group mb-1 mr-3 w-5"></i> Templates</a>
            <a href="/Profile" class="flex items-center px-4 py-3 bg-white bg-opacity-10 rounded-lg text-white"><i class="fa-solid fa-gear mb-1 mr-3 w-5"></i> Settings</a>
        </nav>
        <div class="p-4 border-t border-gray-700">
            <a href="/Logout" class="flex items-center px-4 py-2 text-red-400 hover:text-red-300 transition"><i class="fa-solid fa-arrow-right-from-bracket mr-3"></i> Log Out</a>
        </div>
    </aside>

    <main class="flex-1 overflow-y-auto p-10 w-full max-w-5xl mx-auto">
        <h2 class="text-3xl font-bold text-gray-800 mb-8 border-b pb-4">Account Settings</h2>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Left col: Form -->
            <div class="lg:col-span-2 space-y-8">
                <!-- Profile Section -->
                <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-200">
                    <h3 class="text-xl font-bold text-[#1e3a5f] mb-6"><i class="fa-solid fa-user text-[#f59e0b] mr-2"></i> Personal Information</h3>
                    <form id="profile-form" class="space-y-4 text-sm text-gray-700">
                        <div class="flex items-center space-x-6 mb-6">
                            <img src="https://ui-avatars.com/api/?name=Alex+User&size=100&background=random" alt="Avatar" class="w-24 h-24 rounded-full border-4 border-gray-100 shadow-sm">
                            <div>
                                <button type="button" class="bg-gray-100 border border-gray-300 text-gray-700 px-4 py-2 rounded-lg font-semibold hover:bg-gray-200 transition mb-2">Change Photo</button>
                                <p class="text-xs text-gray-400">JPG, GIF or PNG. Max size of 800K</p>
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block font-semibold mb-1">Full Name</label>
                                <input type="text" class="w-full border rounded p-2 focus:ring-[#f59e0b] outline-none" value="Alex User">
                            </div>
                            <div>
                                <label class="block font-semibold mb-1">Email Address</label>
                                <input type="email" class="w-full border rounded p-2 focus:ring-[#f59e0b] outline-none" value="alex@example.com">
                            </div>
                        </div>

                        <div>
                            <label class="block font-semibold mb-1">Current Password (Required for changes)</label>
                            <input type="password" class="w-full border rounded p-2 focus:ring-[#f59e0b] outline-none" placeholder="Enter current password">
                        </div>
                        <div>
                            <label class="block font-semibold mb-1">New Password</label>
                            <input type="password" class="w-full border rounded p-2 focus:ring-[#f59e0b] outline-none" placeholder="Leave blank to keep same">
                        </div>

                        <div class="pt-4 flex justify-end">
                            <button type="submit" class="bg-[#1e3a5f] text-white px-6 py-2 rounded-lg font-semibold hover:bg-blue-900 transition">Save Changes</button>
                        </div>
                    </form>
                    <!-- API: PUT /api/user/profile -->
                </div>
            </div>

            <!-- Right col: Subscription & History -->
            <div class="space-y-8">
                <!-- Subscription -->
                <div class="bg-gradient-to-br from-[#1e3a5f] to-blue-900 p-8 rounded-xl shadow-lg border border-gray-200 text-white relative overflow-hidden">
                    <div class="absolute -right-4 -top-4 opacity-10">
                        <i class="fa-solid fa-crown text-9xl text-[#f59e0b]"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-2 flex items-center relative z-10"><i class="fa-solid fa-credit-card text-[#f59e0b] mr-2"></i> Subscription</h3>

                    <div class="mb-6 relative z-10 text-sm">
                        <p class="text-gray-300">Current Plan</p>
                        <p class="text-3xl font-extrabold text-white mt-1">Free</p>
                    </div>

                    <p class="text-sm text-gray-300 mb-6 relative z-10">Standard limitations apply. Upgrade for unlimited features and premium ATS checking.</p>

                    <button class="w-full bg-[#f59e0b] text-[#1e3a5f] font-bold py-3 rounded-lg hover:bg-yellow-400 transition relative z-10 shadow-md" onclick="window.location.href='/Pricing'">
                        Upgrade to Pro
                    </button>
                </div>

                <!-- History -->
                <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
                    <h3 class="text-lg font-bold text-gray-800 mb-4 border-b pb-2 text-sm"><i class="fa-solid fa-clock-rotate-left mr-2 text-gray-500"></i> Download History</h3>
                    <ul class="space-y-4 text-sm">
                        <li class="flex justify-between items-center text-gray-600">
                            <span><i class="fa-solid fa-file-pdf mr-2 text-red-500"></i> Software_Engineer_V2.pdf</span>
                            <span class="text-xs text-gray-400">Oct 12</span>
                        </li>
                        <li class="flex justify-between items-center text-gray-600">
                            <span><i class="fa-solid fa-file-pdf mr-2 text-red-500"></i> Resume_Arch.pdf</span>
                            <span class="text-xs text-gray-400">Oct 05</span>
                        </li>
                        <li class="flex justify-between items-center text-gray-600">
                            <span><i class="fa-solid fa-envelope-open-text mr-2 text-blue-500"></i> Google_CoverLetter.pdf</span>
                            <span class="text-xs text-gray-400">Sep 28</span>
                        </li>
                        <li class="flex justify-between items-center text-gray-600">
                            <span><i class="fa-solid fa-file-pdf mr-2 text-red-500"></i> Developer_Resume.pdf</span>
                            <span class="text-xs text-gray-400">Sep 20</span>
                        </li>
                    </ul>
                    <!-- API: GET /api/user/history -->
                </div>
            </div>
        </div>
    </main>
</div>

<script>
    document.getElementById('profile-form').addEventListener('submit', function(e) {
        e.preventDefault();
        alert('Profile updated successfully!');
    });
</script>
