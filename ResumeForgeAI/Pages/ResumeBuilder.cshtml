@page
@{
    ViewData["Title"] = "Resume Builder";
    string templateTheme = Request.Query["template"].ToString().ToLower();
    if (string.IsNullOrEmpty(templateTheme)) {
        templateTheme = "modern";
    }
}

<div class="h-screen flex flex-col bg-gray-50 overflow-hidden">
    <!-- Navbar -->
    <header class="h-16 bg-[#1e3a5f] text-white flex justify-between items-center px-4 shadow-md z-10 shrink-0">
        <div class="flex items-center space-x-4">
            <a href="/Dashboard" class="text-gray-300 hover:text-white"><i class="fa-solid fa-arrow-left"></i> Back</a>
            <h1 class="text-xl font-bold flex items-center">
                <i class="fa-solid fa-file-pen text-[#f59e0b] mr-2"></i>
                Untitled Resume Document
            </h1>
        </div>
        <div class="flex items-center space-x-3">
            <button class="bg-white text-[#1e3a5f] px-4 py-2 rounded text-sm font-semibold hover:bg-gray-100 transition"><i class="fa-solid fa-palette mr-1"></i> Template</button>
            <button class="border border-white text-white px-4 py-2 rounded text-sm font-semibold hover:bg-white hover:text-[#1e3a5f] transition" onclick="alert('Saving...')"><i class="fa-solid fa-floppy-disk mr-1"></i> Save</button>
            <button class="bg-[#f59e0b] text-[#1e3a5f] px-4 py-2 rounded text-sm font-semibold hover:bg-yellow-400 transition" onclick="window.print()"><i class="fa-solid fa-download mr-1"></i> Download PDF</button>
        </div>
    </header>

    <div class="flex-1 flex overflow-hidden">
        <!-- Left Panel: Form -->
        <div class="w-1/3 bg-white border-r border-gray-200 overflow-y-auto z-0 shadow-inner flex flex-col">
            <div class="p-6">
                <h2 class="text-2xl font-bold text-[#1e3a5f] border-b pb-4 mb-6">Resume Details</h2>

                <div class="mb-8">
                    <h3 class="text-lg font-bold text-gray-800 flex items-center mb-4"><i class="fa-regular fa-user text-gray-500 mr-2 text-xl"></i> Personal Info</h3>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm text-gray-700 mb-1">Full Name</label>
                            <input id="input-name" type="text" class="w-full border rounded-lg p-2.5 text-sm focus:ring-1 focus:ring-[#1e3a5f] outline-none" value="Mohammad Naeem">
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm text-gray-700 mb-1">Email</label>
                                <input id="input-email" type="text" class="w-full border rounded-lg p-2.5 text-sm focus:ring-1 focus:ring-[#1e3a5f] outline-none" value="mohammadd">
                            </div>
                            <div>
                                <label class="block text-sm text-gray-700 mb-1">Phone</label>
                                <input id="input-phone" type="text" class="w-full border rounded-lg p-2.5 text-sm focus:ring-1 focus:ring-[#1e3a5f] outline-none" placeholder="(555) 123-4567" value="(555) 123-4567">
                            </div>
                            <div>
                                <label class="block text-sm text-gray-700 mb-1">LinkedIn</label>
                                <input id="input-linkedin" type="text" class="w-full border rounded-lg p-2.5 text-sm focus:ring-1 focus:ring-[#1e3a5f] outline-none" placeholder="linkedin.com/in/johndoe">
                            </div>
                            <div>
                                <label class="block text-sm text-gray-700 mb-1">Location</label>
                                <input id="input-location" type="text" class="w-full border rounded-lg p-2.5 text-sm focus:ring-1 focus:ring-[#1e3a5f] outline-none" placeholder="New York, NY" value="New York, NY">
                            </div>
                        </div>
                    </div>
                </div>

                <h2 class="text-lg font-bold text-gray-800 border-b pb-2 mt-8 mb-4">Professional Summary</h2>
                <textarea id="summary-input" rows="4" class="w-full border rounded p-2 text-sm focus:ring-1 focus:ring-[#f59e0b] outline-none" placeholder="Write a summary or use AI to generate one..."></textarea>

                <h2 class="text-lg font-bold text-gray-800 border-b pb-2 mt-8 mb-4 flex justify-between items-center">
                    Work Experience
                    <button class="text-[#f59e0b] text-sm"><i class="fa-solid fa-plus"></i> Add</button>
                </h2>
                <div class="border border-gray-200 rounded p-4 bg-gray-50 mb-4">
                    <input id="input-exp-title" type="text" placeholder="Job Title" class="w-full border rounded p-2 text-sm mb-2" value="Software Engineer">
                    <input id="input-exp-company" type="text" placeholder="Company" class="w-full border rounded p-2 text-sm mb-2" value="Tech Innovations Inc.">
                    <input id="input-exp-date" type="text" placeholder="Date (e.g. 2020 - Present)" class="w-full border rounded p-2 text-sm mb-2" value="2020 - Present">
                    <textarea id="input-exp-desc" rows="3" class="w-full border rounded p-2 text-sm" placeholder="Descriptions/Bullet points...">Developed and maintained RESTful APIs used by 1M+ users daily. Reduced server response time by 30% through caching and query optimization.</textarea>
                </div>

                <h2 class="text-lg font-bold text-gray-800 border-b pb-2 mt-8 mb-4 flex justify-between items-center">
                    Education
                    <button class="text-[#f59e0b] text-sm"><i class="fa-solid fa-plus"></i> Add</button>
                </h2>
                <div class="border border-gray-200 rounded p-4 bg-gray-50 mb-4">
                    <input id="input-edu-degree" type="text" placeholder="Degree (e.g. BS Computer Science)" class="w-full border rounded p-2 text-sm mb-2" value="Bachelor of Science in Computer Science">
                    <input id="input-edu-school" type="text" placeholder="School/University" class="w-full border rounded p-2 text-sm mb-2" value="University of Technology">
                    <input id="input-edu-date" type="text" placeholder="Date (e.g. 2018 - 2022)" class="w-full border rounded p-2 text-sm mb-2" value="2018 - 2022">
                </div>

                <h2 class="text-lg font-bold text-gray-800 border-b pb-2 mt-8 mb-4 flex justify-between items-center">
                    Skills
                </h2>
                <div class="border border-gray-200 rounded p-4 bg-gray-50 mb-4">
                    <input id="input-skills" type="text" placeholder="e.g. C#, JavaScript, React (comma separated)" class="w-full border rounded p-2 text-sm" value="C#, JavaScript, React, Tailwind CSS">
                </div>

                <h2 class="text-lg font-bold text-gray-800 border-b pb-2 mt-8 mb-4 flex justify-between items-center">
                    Honors & Awards
                    <button class="text-[#f59e0b] text-sm"><i class="fa-solid fa-plus"></i> Add</button>
                </h2>
                <div class="border border-gray-200 rounded p-4 bg-gray-50 mb-4">
                    <input id="input-award-title" type="text" placeholder="Award Title" class="w-full border rounded p-2 text-sm mb-2" value="Dean's List">
                    <input id="input-award-issuer" type="text" placeholder="Issuer/Organization" class="w-full border rounded p-2 text-sm mb-2" value="Duck University">
                    <input id="input-award-date" type="text" placeholder="Date/Year (e.g. 2021 & 2022)" class="w-full border rounded p-2 text-sm mb-2" value="2021 & 2022">
                    <textarea id="input-award-desc" rows="2" class="w-full border rounded p-2 text-sm" placeholder="Description...">Among the 5 percent best students in the 2019/20 and 2020/21 academic year.</textarea>
                </div>

                <h2 class="text-lg font-bold text-gray-800 border-b pb-2 mt-8 mb-4 flex justify-between items-center">
                    Extracurricular Activities
                    <button class="text-[#f59e0b] text-sm"><i class="fa-solid fa-plus"></i> Add</button>
                </h2>
                <div class="border border-gray-200 rounded p-4 bg-gray-50 mb-4">
                    <input id="input-extra-role" type="text" placeholder="Role (e.g. Peer Mentor)" class="w-full border rounded p-2 text-sm mb-2" value="Peer Mentor">
                    <input id="input-extra-org" type="text" placeholder="Organization" class="w-full border rounded p-2 text-sm mb-2" value="Duck Academy">
                    <input id="input-extra-date" type="text" placeholder="Date (e.g. 8/2020 - 12/2021)" class="w-full border rounded p-2 text-sm mb-2" value="8/2020 - 12/2021">
                    <textarea id="input-extra-desc" rows="2" class="w-full border rounded p-2 text-sm" placeholder="Description...">Provided peer-to-peer mentoring for new ducks</textarea>
                </div>

                <h2 class="text-lg font-bold text-gray-800 border-b pb-2 mt-8 mb-4 flex justify-between items-center">
                    Custom Section
                    <button class="text-[#f59e0b] text-sm"><i class="fa-solid fa-plus"></i> Add</button>
                </h2>
                <div class="border border-gray-200 rounded p-4 bg-gray-50 mb-4">
                    <input id="input-custom-section" type="text" placeholder="Section Name (e.g. Projects)" class="w-full border rounded p-2 text-sm mb-2 font-bold" value="Projects">
                    <input id="input-custom-title" type="text" placeholder="Item Title" class="w-full border rounded p-2 text-sm mb-2" value="AI Resume Builder">
                    <input id="input-custom-subtitle" type="text" placeholder="Subtitle / Role" class="w-full border rounded p-2 text-sm mb-2" value="Lead Developer">
                    <input id="input-custom-date" type="text" placeholder="Date" class="w-full border rounded p-2 text-sm mb-2" value="2023 - Present">
                    <textarea id="input-custom-desc" rows="2" class="w-full border rounded p-2 text-sm" placeholder="Description...">Built a full-stack resume builder using .NET 8 and OpenAI.</textarea>
                </div>
            </div>
        </div>

        <!-- Center Panel: Live Preview -->
        <div class="w-1/3 bg-gray-200 flex-1 overflow-y-auto p-8 z-0 block">
            <div id="resume-preview" class="template-@(templateTheme) mx-auto w-full max-w-3xl bg-white shadow-2xl p-10 h-max min-h-[1056px] print:min-h-0 print:shadow-none print:p-0 font-sans">
                <!-- Header -->
                <div class="text-center mb-6">
                    <h1 class="text-4xl uppercase tracking-wider mb-2">
                        <span id="preview-name" class="font-black text-gray-900">Mohammad Naeem</span> 
                    </h1>
                    <div class="flex justify-center flex-wrap gap-x-4 gap-y-1 text-sm text-gray-700">
                        <span class="flex items-center"><i class="fa-solid fa-envelope text-red-600 mr-2"></i><span id="preview-email">mohammadd</span></span>
                        <span class="text-red-600">•</span>
                        <span class="flex items-center"><span id="preview-location">New York, NY</span></span>
                        <span class="text-red-600">•</span>
                        <span class="flex items-center"><i class="fa-solid fa-phone text-red-600 mr-2"></i><span id="preview-phone">(555) 123-4567</span></span>
                    </div>
                    <div class="flex justify-center flex-wrap gap-x-4 gap-y-1 text-sm text-gray-700 mt-1" id="preview-socials">
                        <span class="flex items-center" id="preview-linkedin-container" style="display:none;"><i class="fa-brands fa-linkedin text-red-600 mr-2"></i><span id="preview-linkedin"></span></span>
                    </div>
                </div>

                <!-- Summary -->
                <div class="mb-5">
                    <div class="flex items-center mb-2">
                        <h2 class="text-xl font-bold text-red-600 uppercase tracking-widest mr-2">Summary</h2>
                        <div class="flex-grow border-b-2 border-red-600 mt-2"></div>
                    </div>
                    <p class="text-gray-700 text-sm leading-relaxed" id="summary-preview">Passionate software engineer with 5 years of experience building scalable web applications. Strong focus on modern cloud architectures.</p>
                </div>

                <!-- Education -->
                <div class="mb-5">
                    <div class="flex items-center mb-4">
                        <h2 class="text-xl font-bold text-red-600 uppercase tracking-widest mr-2">Education</h2>
                        <div class="flex-grow border-b-2 border-red-600 mt-2"></div>
                    </div>
                    <div class="mb-3">
                        <div class="flex justify-between items-baseline">
                            <h3 id="preview-edu-degree" class="font-bold text-gray-900 uppercase">Bachelor of Science in Computer Science</h3>
                            <span id="preview-edu-date" class="text-gray-800 font-semibold text-sm">2018 - 2022</span>
                        </div>
                        <div class="flex justify-between items-baseline mt-1">
                            <p id="preview-edu-school" class="text-gray-800 text-sm">University of Technology</p>
                            <span class="text-gray-500 italic text-sm text-right">New York, USA</span>
                        </div>
                    </div>
                </div>

                <!-- Experience -->
                <div class="mb-5">
                    <div class="flex items-center mb-4">
                        <h2 class="text-xl font-bold text-red-600 uppercase tracking-widest mr-2">Experience</h2>
                        <div class="flex-grow border-b-2 border-red-600 mt-2"></div>
                    </div>
                    <div class="mb-4">
                        <div class="flex justify-between items-baseline">
                            <h3 id="preview-exp-title" class="font-bold text-gray-900 uppercase">Software Engineer</h3>
                            <span id="preview-exp-date" class="text-gray-800 font-semibold text-sm">2020 - Present</span>
                        </div>
                        <div class="flex justify-between items-baseline mt-1 mb-1">
                            <p id="preview-exp-company" class="text-gray-800 text-sm">Tech Innovations Inc.</p>
                            <span class="text-gray-500 italic text-sm text-right">Remote</span>
                        </div>
                        <ul class="list-disc list-inside text-gray-700 text-sm space-y-1">
                            <li id="preview-exp-desc">Developed and maintained RESTful APIs used by 1M+ users daily. Reduced server response time by 30% through caching and query optimization.</li>
                        </ul>
                    </div>
                </div>

                <!-- Skills -->
                <div class="mb-5">
                    <div class="flex items-center mb-4">
                        <h2 class="text-xl font-bold text-red-600 uppercase tracking-widest mr-2">Skills</h2>
                        <div class="flex-grow border-b-2 border-red-600 mt-2"></div>
                    </div>
                    <div class="text-sm">
                        <div class="flex">
                            <span class="font-bold text-gray-900 w-1/4 uppercase">Core Skills</span>
                            <span id="preview-skills" class="text-gray-700 w-3/4">C#, JavaScript, React, Tailwind CSS</span>
                        </div>
                    </div>
                </div>

                <!-- Honors & Awards -->
                <div class="mb-5">
                    <div class="flex items-center mb-4">
                        <h2 class="text-xl font-bold text-red-600 uppercase tracking-widest mr-2">Honors & Awards</h2>
                        <div class="flex-grow border-b-2 border-red-600 mt-2"></div>
                    </div>
                    <div class="mb-2">
                        <div class="flex justify-between items-baseline">
                            <h3 id="preview-award-title" class="font-bold text-gray-900 uppercase">Dean's List</h3>
                            <span id="preview-award-date" class="text-gray-800 font-semibold text-sm">2021 & 2022</span>
                        </div>
                        <div class="flex justify-between items-baseline mt-1 mb-1">
                            <p id="preview-award-issuer" class="text-gray-800 text-sm">Duck University</p>
                        </div>
                        <p id="preview-award-desc" class="text-gray-700 text-sm">Among the 5 percent best students in the 2019/20 and 2020/21 academic year.</p>
                    </div>
                </div>

                <!-- Extracurricular Activities -->
                <div class="mb-5">
                    <div class="flex items-center mb-4">
                        <h2 class="text-xl font-bold text-red-600 uppercase tracking-widest mr-2">Extracurricular Activities</h2>
                        <div class="flex-grow border-b-2 border-red-600 mt-2"></div>
                    </div>
                    <div class="mb-2">
                        <div class="flex justify-between items-baseline">
                            <h3 id="preview-extra-role" class="font-bold text-gray-900 uppercase">Peer Mentor</h3>
                            <span id="preview-extra-date" class="text-gray-800 font-semibold text-sm">8/2020 - 12/2021</span>
                        </div>
                        <div class="flex justify-between items-baseline mt-1 mb-1">
                            <p id="preview-extra-org" class="text-gray-800 text-sm">Duck Academy</p>
                        </div>
                        <p id="preview-extra-desc" class="text-gray-700 text-sm">Provided peer-to-peer mentoring for new ducks</p>
                    </div>
                </div>

                <!-- Custom Section -->
                <div class="mb-5">
                    <div class="flex items-center mb-4">
                        <h2 id="preview-custom-section" class="text-xl font-bold text-red-600 uppercase tracking-widest mr-2">Projects</h2>
                        <div class="flex-grow border-b-2 border-red-600 mt-2"></div>
                    </div>
                    <div class="mb-2">
                        <div class="flex justify-between items-baseline">
                            <h3 id="preview-custom-title" class="font-bold text-gray-900 uppercase">AI Resume Builder</h3>
                            <span id="preview-custom-date" class="text-gray-800 font-semibold text-sm">2023 - Present</span>
                        </div>
                        <div class="flex justify-between items-baseline mt-1 mb-1">
                            <p id="preview-custom-subtitle" class="text-gray-800 text-sm">Lead Developer</p>
                        </div>
                        <p id="preview-custom-desc" class="text-gray-700 text-sm">Built a full-stack resume builder using .NET 8 and OpenAI.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Panel: AI Assistant -->
        <div class="w-1/4 bg-white border-l border-gray-200 flex flex-col z-0">
            <div class="p-6 border-b border-gray-200 bg-[#1e3a5f] text-white">
                <h2 class="text-xl font-bold flex items-center">
                    <i class="fa-solid fa-wand-magic-sparkles text-[#f59e0b] mr-2"></i> AI Assistant
                </h2>
                <p class="text-xs text-gray-300 mt-2">Tailor your resume instantly.</p>
            </div>
            <div class="flex-1 p-6 overflow-y-auto">
                <label class="block text-sm font-medium text-gray-700 mb-2">Target Job Description</label>
                <textarea id="ai-jd-input" rows="6" class="w-full border rounded p-3 text-sm focus:ring-1 focus:ring-[#f59e0b] outline-none mb-4" placeholder="Paste the job requirements here..."></textarea>
                <button id="btn-generate" class="w-full bg-[#1e3a5f] text-white font-bold py-3 rounded-lg hover:bg-blue-900 transition flex items-center justify-center">
                    <i class="fa-solid fa-bolt text-[#f59e0b] mr-2"></i> Generate Bullet Points
                </button>
                <!-- API: POST /api/resume/generate -->

                <div id="ai-loading" class="hidden text-center py-8">
                    <i class="fa-solid fa-circle-notch fa-spin text-3xl text-[#f59e0b] mb-4"></i>
                    <p class="text-sm text-gray-500 font-medium">Analyzing description and generating content...</p>
                </div>

                <div id="ai-results" class="hidden mt-8">
                    <h3 class="font-bold text-gray-800 text-sm uppercase tracking-wider mb-4 border-b pb-2">Suggestions</h3>
                    <div class="space-y-3">
                        <div class="p-3 bg-blue-50 border border-blue-100 rounded-lg cursor-pointer hover:bg-blue-100 transition shadow-sm" onclick="applyAiText('Engineered a high-performance cloud-native microservices architecture...')">
                            <p class="text-sm text-gray-700">Engineered a high-performance cloud-native microservices architecture, improving system scalability by 40%.</p>
                            <span class="text-xs text-[#f59e0b] font-bold mt-2 inline-block">+ Apply</span>
                        </div>
                        <div class="p-3 bg-blue-50 border border-blue-100 rounded-lg cursor-pointer hover:bg-blue-100 transition shadow-sm" onclick="applyAiText('Spearheaded migration of legacy systems to AWS...')">
                            <p class="text-sm text-gray-700">Spearheaded migration of legacy REST APIs to AWS Serverless architecture.</p>
                            <span class="text-xs text-[#f59e0b] font-bold mt-2 inline-block">+ Apply</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('btn-generate').addEventListener('click', function() {
        const btn = this;
        const loading = document.getElementById('ai-loading');
        const results = document.getElementById('ai-results');

        if(document.getElementById('ai-jd-input').value.trim() === '') {
            alert('Please paste a job description first.');
            return;
        }

        btn.disabled = true;
        btn.classList.add('opacity-50');
        loading.classList.remove('hidden');
        results.classList.add('hidden');

        // Mock AI request
        setTimeout(() => {
            loading.classList.add('hidden');
            results.classList.remove('hidden');
            btn.disabled = false;
            btn.classList.remove('opacity-50');
        }, 2000); // 2 second mock delay
    });

    function applyAiText(text) {
        document.getElementById('summary-input').value = text;
        document.getElementById('summary-preview').innerText = text;
        alert('Text applied to resume!');
    }

    // Live binding
    function bindInput(inputId, previewId) {
        const input = document.getElementById(inputId);
        const preview = document.getElementById(previewId);
        if(input && preview) {
            input.addEventListener('input', function() {
                preview.innerText = this.value;
            });
            // trigger on load
            preview.innerText = input.value;
        }
    }

    bindInput('input-name', 'preview-name');
    bindInput('input-location', 'preview-location');
    bindInput('input-email', 'preview-email');
    bindInput('input-phone', 'preview-phone');
    bindInput('input-exp-title', 'preview-exp-title');
    bindInput('input-exp-company', 'preview-exp-company');
    bindInput('input-exp-date', 'preview-exp-date');
    bindInput('input-exp-desc', 'preview-exp-desc');
    bindInput('input-edu-degree', 'preview-edu-degree');
    bindInput('input-edu-school', 'preview-edu-school');
    bindInput('input-edu-date', 'preview-edu-date');
    bindInput('input-skills', 'preview-skills');

    // Bindings for Honors & Awards
    bindInput('input-award-title', 'preview-award-title');
    bindInput('input-award-issuer', 'preview-award-issuer');
    bindInput('input-award-date', 'preview-award-date');
    bindInput('input-award-desc', 'preview-award-desc');

    // Bindings for Extracurricular Activities
    bindInput('input-extra-role', 'preview-extra-role');
    bindInput('input-extra-org', 'preview-extra-org');
    bindInput('input-extra-date', 'preview-extra-date');
    bindInput('input-extra-desc', 'preview-extra-desc');

    // Bindings for Custom Section
    bindInput('input-custom-section', 'preview-custom-section');
    bindInput('input-custom-title', 'preview-custom-title');
    bindInput('input-custom-subtitle', 'preview-custom-subtitle');
    bindInput('input-custom-date', 'preview-custom-date');
    bindInput('input-custom-desc', 'preview-custom-desc');

    // Special handler for summary to provide default fallback text
    const summaryInput = document.getElementById('summary-input');
    const summaryPreview = document.getElementById('summary-preview');
    if (summaryInput && summaryPreview) {
        summaryInput.addEventListener('input', function() {
            summaryPreview.innerText = this.value || 'Write a summary or use AI to generate one...';
        });
    }

    // Dynamic +Add cloning logic
    document.querySelectorAll('button:has(.fa-plus)').forEach(btn => {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            let header = this.closest('h2');
            let inputGroup = header.nextElementSibling;

            let sectionType = '';
            if (header.innerText.includes('Experience')) sectionType = 'exp';
            else if (header.innerText.includes('Education')) sectionType = 'edu';
            else if (header.innerText.includes('Awards')) sectionType = 'award';
            else if (header.innerText.includes('Activities')) sectionType = 'extra';
            else if (header.innerText.includes('Custom')) sectionType = 'custom';

            if (inputGroup && inputGroup.classList.contains('bg-gray-50') && sectionType) {
                let uniqueId = '_' + Date.now();
                let inputClone = inputGroup.cloneNode(true);
                let inputMap = {}; // Maps oldId to input element

                inputClone.querySelectorAll('input, textare').forEach(input => {
                    let oldId = input.id;
                    input.value = '';
                    if (oldId) {
                        input.id = oldId + uniqueId;
                        inputMap[oldId] = input;
                    }
                });

                inputClone.querySelectorAll('textarea').forEach(input => {
                    let oldId = input.id;
                    input.value = '';
                    if (oldId) {
                        input.id = oldId + uniqueId;
                        inputMap[oldId] = input;
                    }
                });

                inputGroup.parentNode.insertBefore(inputClone, inputGroup.nextSibling);

                // Clone preview corresponding side
                let identifierId = 'preview-' + sectionType + (sectionType==='extra' ? '-role' : (sectionType==='edu' ? '-degree' : '-title'));
                let firstPreview = document.getElementById(identifierId);

                if (firstPreview) {
                    let previewContainer = firstPreview.closest('.mb-4') || firstPreview.closest('.mb-3') || firstPreview.closest('.mb-2');
                    if (previewContainer) {
                        let previewClone = previewContainer.cloneNode(true);

                        previewClone.querySelectorAll('[id]').forEach(el => {
                            let oldId = el.id;
                            let correspondingInputId = oldId.replace('preview-', 'input-');
                            if (inputMap[correspondingInputId]) {
                                el.id = oldId + uniqueId;
                                el.innerText = '';
                            }
                        });

                        previewContainer.parentNode.insertBefore(previewClone, previewContainer.nextSibling);

                        // Bind the new inputs
                        for (let oldInputId in inputMap) {
                            let newPreviewId = oldInputId.replace('input-', 'preview-') + uniqueId;
                            bindInput(inputMap[oldInputId].id, newPreviewId);
                        }
                    }
                }
            }
        });
    });

    // Special handler for LinkedIn
    const linkedInInput = document.getElementById('input-linkedin');
    const linkedInPreview = document.getElementById('preview-linkedin');
    const linkedInContainer = document.getElementById('preview-linkedin-container');
    if(linkedInInput && linkedInPreview && linkedInContainer) {
        linkedInInput.addEventListener('input', function() {
            linkedInPreview.innerText = this.value;
            linkedInContainer.style.display = this.value.trim() ? 'flex' : 'none';
        });
        linkedInInput.dispatchEvent(new Event('input')); // Trigger initial state
    }
</script>

