@page
@{
    ViewData["Title"] = "Templates";
}

<div class="flex h-screen bg-gray-50">
    <!-- Sidebar -->
    <aside class="w-64 bg-[#1e3a5f] text-white flex flex-col shadow-lg">
        <div class="h-16 flex items-center px-6 border-b border-gray-700">
            <h1 class="text-xl font-bold text-[#f59e0b]"><i class="fa-solid fa-file-signature mr-2"></i>ResumeForge</h1>
        </div>
        <nav class="flex-1 px-4 py-6 space-y-2">
            <a href="/Dashboard" class="flex items-center px-4 py-3 text-gray-300 hover:bg-white hover:bg-opacity-5 rounded-lg transition"><i class="fa-solid fa-house mb-1 mr-3 w-5"></i> Dashboard</a>
            <a href="/ResumeBuilder" class="flex items-center px-4 py-3 text-gray-300 hover:bg-white hover:bg-opacity-5 rounded-lg transition"><i class="fa-solid fa-file-lines mb-1 mr-3 w-5"></i> Resume Builder</a>
            <a href="/CoverLetter" class="flex items-center px-4 py-3 text-gray-300 hover:bg-white hover:bg-opacity-5 rounded-lg transition"><i class="fa-solid fa-envelope mb-1 mr-3 w-5"></i> Cover Letters</a>
            <a href="/AtsChecker" class="flex items-center px-4 py-3 text-gray-300 hover:bg-white hover:bg-opacity-5 rounded-lg transition"><i class="fa-solid fa-chart-line mb-1 mr-3 w-5"></i> ATS Checker</a>
            <a href="/Templates" class="flex items-center px-4 py-3 bg-white bg-opacity-10 rounded-lg text-white"><i class="fa-solid fa-layer-group mb-1 mr-3 w-5"></i> Templates</a>
        </nav>
    </aside>

    <main class="flex-1 overflow-y-auto w-full p-10">
        <div class="mb-10 text-center">
            <h2 class="text-4xl font-extrabold text-[#1e3a5f] mb-4">Professionally Designed Templates</h2>
            <p class="text-gray-600 text-lg">Choose a template that fits your industry and personality. All templates are ATS-optimized.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
            <!-- Template 1 -->
            <div class="bg-white rounded-xl shadow-md border border-gray-100 overflow-hidden hover:shadow-xl transition relative group">
                <div class="aspect-w-3 aspect-h-4 bg-gray-200">
                    <!-- Mock thumbnail -->
                    <div class="w-full h-64 bg-white border border-gray-300 flex flex-col p-4">
                        <div class="h-6 bg-gray-800 w-1/2 mx-auto mb-2"></div>
                        <div class="h-2 bg-gray-400 w-1/3 mx-auto mb-6"></div>
                        <div class="space-y-4">
                            <div>
                                <div class="h-3 bg-gray-600 w-1/4 mb-2"></div>
                                <div class="border-b border-gray-300 w-full mb-2"></div>
                                <div class="h-2 bg-gray-300 w-full mb-1"></div>
                                <div class="h-2 bg-gray-300 w-5/6"></div>
                            </div>
                            <div>
                                <div class="h-3 bg-gray-600 w-1/4 mb-2"></div>
                                <div class="border-b border-gray-300 w-full mb-2"></div>
                                <div class="h-2 bg-gray-300 w-full mb-1"></div>
                                <div class="h-2 bg-gray-300 w-4/5"></div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- API: GET /api/templates -->
                <div class="p-6 text-center">
                    <h3 class="text-xl font-bold text-gray-800 mb-2">Classic</h3>
                    <p class="text-sm text-gray-500 mb-4">Traditional black & white layout</p>
                    <button class="w-full bg-[#1e3a5f] text-white py-2 rounded font-semibold hover:bg-blue-900 transition" onclick="window.location.href='/ResumeBuilder?template=classic'">Use This Template</button>
                </div>
            </div>

            <!-- Template 2 -->
            <div class="bg-white rounded-xl shadow-md border border-gray-100 overflow-hidden hover:shadow-xl transition relative group">
                <div class="aspect-w-3 aspect-h-4 bg-gray-200">
                    <div class="w-full h-64 bg-white border border-gray-300 flex">
                        <div class="w-1/4 bg-[#1e3a5f] h-full p-2 flex flex-col gap-2 shadow-inner">
                            <div class="h-8 w-8 rounded-full bg-white bg-opacity-30 mx-auto mt-2"></div>
                            <div class="h-2 bg-white bg-opacity-50 w-3/4 mx-auto mt-4"></div>
                            <div class="h-2 bg-white bg-opacity-50 w-1/2 mx-auto"></div>
                            <div class="h-1 bg-white bg-opacity-30 w-full mt-4"></div>
                            <div class="h-2 bg-white bg-opacity-50 w-3/4 mx-auto mt-2"></div>
                        </div>
                        <div class="w-3/4 p-4 space-y-4">
                            <div class="h-5 bg-gray-800 w-3/4"></div>
                            <div class="h-2 bg-[#f59e0b] w-1/3 mb-4"></div>
                            <div class="space-y-2">
                                <div class="h-2 bg-gray-300 w-full"></div>
                                <div class="h-2 bg-gray-300 w-5/6"></div>
                                <div class="h-2 bg-gray-300 w-full"></div>
                                <div class="h-2 bg-gray-300 w-4/5"></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="p-6 text-center">
                    <h3 class="text-xl font-bold text-gray-800 mb-2 flex justify-center items-center">Modern <i class="fa-solid fa-fire text-orange-500 ml-2 text-sm"></i></h3>
                    <p class="text-sm text-gray-500 mb-4">Clean lines with an accent sidebar</p>
                    <button class="w-full bg-[#1e3a5f] text-white py-2 rounded font-semibold hover:bg-blue-900 transition" onclick="window.location.href='/ResumeBuilder?template=modern'">Use This Template</button>
                </div>
            </div>

            <!-- Template 3 (Locked) -->
            <div class="bg-gray-50 rounded-xl shadow border border-gray-200 overflow-hidden relative group opacity-90">
                <div class="absolute inset-0 bg-black bg-opacity-40 z-10 hidden group-hover:flex flex-col items-center justify-center transition p-6 text-center">
                    <i class="fa-solid fa-lock text-3xl text-[#f59e0b] mb-4"></i>
                    <h4 class="text-white font-bold text-lg mb-2">Pro Template</h4>
                    <p class="text-gray-300 text-sm mb-4">Upgrade to Pro to unlock this premium design.</p>
                    <a href="/Pricing" class="bg-[#f59e0b] text-[#1e3a5f] px-6 py-2 rounded font-bold hover:bg-yellow-400">Upgrade Now</a>
                </div>
                <!-- API: GET /api/user/subscription -->
                <div class="aspect-w-3 aspect-h-4 bg-gray-200 filter blur-sm transition duration-300 group-hover:blur-md">
                    <div class="w-full h-64 bg-white border border-gray-300 flex flex-col">
                        <div class="w-full h-12 bg-gray-100 border-b border-gray-200 p-3 flex gap-3 items-center">
                            <div class="h-6 w-6 bg-[#f59e0b] rounded-sm"></div>
                            <div class="h-4 bg-gray-800 w-1/2"></div>
                        </div>
                        <div class="flex flex-1 p-3 gap-3">
                            <div class="w-2/3 space-y-3">
                                <div class="h-3 bg-gray-800 w-1/3 border-b-2 border-[#1e3a5f] pb-1 mb-2"></div>
                                <div class="h-2 bg-gray-300 w-full"></div>
                                <div class="h-2 bg-gray-300 w-full"></div>
                                <div class="h-2 bg-gray-300 w-5/6"></div>
                                <div class="h-3 bg-gray-800 w-1/3 border-b-2 border-[#1e3a5f] pb-1 mt-4 mb-2"></div>
                                <div class="h-2 bg-gray-300 w-full"></div>
                                <div class="h-2 bg-gray-300 w-4/5"></div>
                            </div>
                            <div class="w-1/3 space-y-2 border-l border-gray-200 pl-3">
                                <div class="h-2 bg-gray-500 w-2/3 mb-2"></div>
                                <div class="h-2 bg-gray-200 w-full"></div>
                                <div class="h-2 bg-gray-200 w-full"></div>
                                <div class="h-2 bg-gray-200 w-3/4"></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="p-6 text-center">
                    <h3 class="text-xl font-bold text-gray-500 mb-2 flex justify-center items-center">Executive <i class="fa-solid fa-star text-[#f59e0b] ml-2 text-sm"></i></h3>
                    <p class="text-sm text-gray-400 mb-4">Premium look for senior roles</p>
                    <button class="w-full bg-gray-300 text-gray-600 py-2 rounded font-semibold cursor-not-allowed">Locked</button>
                </div>
            </div>

            <!-- Template 4: Creative -->
            <div class="bg-white rounded-xl shadow-md border border-gray-100 overflow-hidden hover:shadow-xl transition relative group flex flex-col">
                <div class="aspect-w-3 aspect-h-4 bg-gray-200">
                    <div class="w-full h-64 bg-white border border-gray-300 p-4 flex flex-col">
                        <div class="flex items-center gap-4 mb-4">
                            <div class="h-12 w-12 rounded-full bg-[#f59e0b]"></div>
                            <div class="space-y-2 flex-1">
                                <div class="h-5 bg-gray-800 w-1/2"></div>
                                <div class="h-2 bg-gray-400 w-1/3"></div>
                            </div>
                        </div>
                        <div class="flex gap-4 flex-1">
                            <div class="w-1/3 border-r border-gray-200 pr-2 space-y-4 mt-2">
                                <div class="flex gap-2"><div class="h-3 w-3 rounded-full bg-[#1e3a5f] shrink-0 mt-0.5"></div><div class="h-2 bg-gray-400 w-full mt-1"></div></div>
                                <div class="flex gap-2"><div class="h-3 w-3 rounded-full bg-[#1e3a5f] shrink-0 mt-0.5"></div><div class="h-2 bg-gray-400 w-5/6 mt-1"></div></div>
                                <div class="flex gap-2"><div class="h-3 w-3 rounded-full bg-[#1e3a5f] shrink-0 mt-0.5"></div><div class="h-2 bg-gray-400 w-full mt-1"></div></div>
                            </div>
                            <div class="w-2/3 space-y-3 pl-2 mt-2">
                                <div class="h-3 bg-gray-800 w-1/3 mb-2 rounded"></div>
                                <div class="h-2 bg-gray-300 w-full rounded"></div>
                                <div class="h-2 bg-gray-300 w-5/6 rounded"></div>
                                <div class="h-3 bg-gray-800 w-1/3 mt-4 mb-2 rounded"></div>
                                <div class="h-2 bg-gray-300 w-full rounded"></div>
                                <div class="h-2 bg-gray-300 w-4/5 rounded"></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="p-6 text-center mt-auto">
                    <h3 class="text-xl font-bold text-gray-800 mb-2">Creative</h3>
                    <p class="text-sm text-gray-500 mb-4">Icon-based sections</p>
                    <button class="w-full border border-[#1e3a5f] text-[#1e3a5f] py-2 rounded font-semibold hover:bg-gray-50 transition" onclick="window.location.href='/ResumeBuilder?template=creative'">Use Template</button>
                </div>
            </div>

            <!-- Template 5: Minimal -->
            <div class="bg-white rounded-xl shadow-md border border-gray-100 overflow-hidden hover:shadow-xl transition relative group flex flex-col">
                <div class="aspect-w-3 aspect-h-4 bg-gray-200">
                    <div class="w-full h-64 bg-white border border-gray-300 p-8 flex flex-col items-start">
                        <div class="h-6 bg-gray-800 w-2/5 mb-2"></div>
                        <div class="h-2 bg-gray-400 w-1/4 mb-6"></div>

                        <div class="w-full space-y-6">
                            <div>
                                <div class="h-2 bg-gray-400 w-1/5 mb-3 uppercase tracking-widest"></div>
                                <div class="h-2 bg-gray-200 w-full mb-2"></div>
                                <div class="h-2 bg-gray-200 w-3/4"></div>
                            </div>
                            <div>
                                <div class="h-2 bg-gray-400 w-1/5 mb-3 uppercase tracking-widest"></div>
                                <div class="h-2 bg-gray-200 w-full mb-2"></div>
                                <div class="h-2 bg-gray-200 w-5/6 mb-2"></div>
                                <div class="h-2 bg-gray-200 w-4/5"></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="p-6 text-center mt-auto">
                    <h3 class="text-xl font-bold text-gray-800 mb-2">Minimal</h3>
                    <p class="text-sm text-gray-500 mb-4">Lots of whitespace</p>
                    <button class="w-full border border-[#1e3a5f] text-[#1e3a5f] py-2 rounded font-semibold hover:bg-gray-50 transition" onclick="window.location.href='/ResumeBuilder?template=minimal'">Use Template</button>
                </div>
            </div>

            <!-- Template 6: Tech -->
            <div class="bg-white rounded-xl shadow-md border border-gray-100 overflow-hidden hover:shadow-xl transition relative group flex flex-col">
                <div class="aspect-w-3 aspect-h-4 bg-gray-200">
                    <div class="w-full h-64 bg-[#0d1117] border border-gray-800 p-5 font-mono text-xs flex flex-col space-y-3">
                        <div class="flex items-center gap-2 mb-2"><span class="text-green-500 font-bold">></span><div class="h-3 bg-green-500 w-1/2"></div></div>
                        <div class="h-2 bg-gray-500 w-1/3 mb-4"></div>

                        <div class="flex items-center gap-2"><span class="text-blue-400 font-bold">#</span><div class="h-2 bg-blue-400 w-1/4"></div></div>
                        <div class="h-2 bg-gray-600 w-full ml-4"></div>
                        <div class="h-2 bg-gray-600 w-5/6 ml-4"></div>

                        <div class="flex items-center gap-2 mt-3"><span class="text-blue-400 font-bold">#</span><div class="h-2 bg-blue-400 w-1/4"></div></div>
                        <div class="h-2 bg-gray-600 w-full ml-4"></div>
                        <div class="h-2 bg-gray-600 w-3/4 ml-4"></div>
                    </div>
                </div>
                <div class="p-6 text-center mt-auto">
                    <h3 class="text-xl font-bold text-gray-800 mb-2">Tech</h3>
                    <p class="text-sm text-gray-500 mb-4">Developer-focused layout</p>
                    <button class="w-full border border-[#1e3a5f] text-[#1e3a5f] py-2 rounded font-semibold hover:bg-gray-50 transition" onclick="window.location.href='/ResumeBuilder?template=tech'">Use Template</button>
                </div>
            </div>
        </div>
    </main>
</div>
