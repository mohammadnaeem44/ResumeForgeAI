@page "/"
@{
    ViewData["Title"] = "Build ATS-Optimized Resumes with AI in Seconds";
}

<!-- Navbar -->
<nav class="bg-[#1e3a5f] text-white p-4">
    <div class="container mx-auto flex justify-between items-center">
        <div class="text-2xl font-bold tracking-tight text-[#f59e0b]">
            <i class="fa-solid fa-file-signature mr-2"></i>ResumeForge AI
        </div>
        <div class="hidden md:flex space-x-6 items-center">
            <a href="/Index" class="hover:text-[#f59e0b] transition">Home</a>
            <a href="/Pricing" class="hover:text-[#f59e0b] transition">Pricing</a>
            <a href="/Templates" class="hover:text-[#f59e0b] transition">Templates</a>
            <a href="/Login" class="text-white hover:text-[#f59e0b] font-medium transition">Login</a>
            <a href="/Register" class="bg-[#f59e0b] text-[#1e3a5f] px-5 py-2 rounded-lg font-bold hover:bg-yellow-400 transition">Sign Up</a>
        </div>
    </div>
</nav>

<!-- Hero Section -->
<section class="bg-[#1e3a5f] text-white py-20">
    <div class="container mx-auto text-center px-4">
        <h1 class="text-5xl md:text-6xl font-bold mb-6">Build ATS-Optimized<br/><span class="text-[#f59e0b]">Resumes with AI</span> in Seconds</h1>
        <p class="text-lg text-gray-300 mb-10 max-w-2xl mx-auto">Stop guessing what recruiters want. Our AI-powered builder creates perfect professional resumes and cover letters for top companies.</p>
        <div class="flex justify-center space-x-4">
            <a href="/Register" class="bg-[#f59e0b] text-[#1e3a5f] px-8 py-3 rounded-lg font-bold text-lg hover:bg-yellow-400 shadow-lg transition">Get Started Free</a>
            <a href="#features" class="border border-white text-white px-8 py-3 rounded-lg font-bold text-lg hover:bg-white hover:text-[#1e3a5f] transition">See Demo</a>
        </div>
    </div>
</section>

<!-- Features Section -->
<section id="features" class="py-20 bg-gray-50 text-center">
    <div class="container mx-auto px-4">
        <h2 class="text-4xl font-bold mb-12 text-[#1e3a5f]">Powerful Features to Land the Job</h2>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
            <div class="bg-white p-8 rounded-xl shadow-sm hover:shadow-md transition">
                <i class="fa-solid fa-robot text-4xl text-[#f59e0b] mb-4"></i>
                <h3 class="text-xl font-bold mb-2">AI Resume Builder</h3>
                <p class="text-gray-600">Instantly generate professional summaries and bullet points tailored to your role.</p>
            </div>
            <div class="bg-white p-8 rounded-xl shadow-sm hover:shadow-md transition">
                <i class="fa-solid fa-envelope-open-text text-4xl text-[#f59e0b] mb-4"></i>
                <h3 class="text-xl font-bold mb-2">Cover Letter Gen</h3>
                <p class="text-gray-600">Create highly targeted cover letters simply by pasting the job description.</p>
            </div>
            <div class="bg-white p-8 rounded-xl shadow-sm hover:shadow-md transition">
                <i class="fa-solid fa-magnifying-glass-chart text-4xl text-[#f59e0b] mb-4"></i>
                <h3 class="text-xl font-bold mb-2">ATS Score Checker</h3>
                <p class="text-gray-600">Analyze your resume against precise job requirements to boost interview odds.</p>
            </div>
            <div class="bg-white p-8 rounded-xl shadow-sm hover:shadow-md transition">
                <i class="fa-solid fa-layer-group text-4xl text-[#f59e0b] mb-4"></i>
                <h3 class="text-xl font-bold mb-2">Multiple Templates</h3>
                <p class="text-gray-600">Choose from 6 stunning, recruiter-approved layouts for any industry.</p>
            </div>
        </div>
    </div>
</section>

<!-- Footer -->
<footer class="bg-gray-900 text-gray-400 py-12 text-center">
    <p>&copy; 2026 ResumeForge AI. All rights reserved.</p>
</footer>
