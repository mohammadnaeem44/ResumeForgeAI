@page
@model ResumeForgeAI.Pages.LoginModel
@{
    ViewData["Title"] = "Sign In";
}

<div class="min-h-screen bg-gray-50 flex flex-col justify-center py-12 sm:px-6 lg:px-8">
    <div class="sm:mx-auto sm:w-full sm:max-w-md">
        <div class="text-center text-3xl font-bold tracking-tight text-[#1e3a5f]">
            <i class="fa-solid fa-file-signature text-[#f59e0b] mr-2"></i>ResumeForge AI
        </div>
        <h2 class="mt-6 text-center text-3xl font-extrabold text-gray-900">Sign in to your account</h2>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="mt-4 bg-red-50 border-l-4 border-red-500 p-4 text-red-700">
                <p>@Model.ErrorMessage</p>
            </div>
        }
    </div>

    <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
        <div class="bg-white py-8 px-4 shadow sm:rounded-lg sm:px-10">
            <form method="post" class="space-y-6">
                <div>
                    <label for="email" class="block text-sm font-medium text-gray-700">Email address</label>
                    <div class="mt-1">
                        <input id="email" name="email" type="email" autocomplete="email" required class="appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-[#f59e0b] focus:border-[#f59e0b] sm:text-sm">
                    </div>
                </div>

                <div>
                    <label for="password" class="block text-sm font-medium text-gray-700">Password</label>
                    <div class="mt-1">
                        <input id="password" name="password" type="password" autocomplete="current-password" required class="appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-[#f59e0b] focus:border-[#f59e0b] sm:text-sm">
                    </div>
                </div>

                <div class="flex items-center justify-between">
                    <div class="flex items-center">
                        <input id="remember-me" name="remember-me" type="checkbox" class="h-4 w-4 text-[#1e3a5f] focus:ring-[#f59e0b] border-gray-300 rounded">
                        <label for="remember-me" class="ml-2 block text-sm text-gray-900">Remember me</label>
                    </div>

                    <div class="text-sm">
                        <a href="#" class="font-medium text-[#1e3a5f] hover:text-[#f59e0b]">Forgot your password?</a>
                    </div>
                </div>

                <div>
                    <button type="submit" class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-[#1e3a5f] bg-[#f59e0b] hover:bg-yellow-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#f59e0b]">
                        Sign in
                    </button>
                    <!-- API: POST /api/auth/login -->
                </div>
            </form>
            <div class="mt-6 text-center">
                <p class="text-sm text-gray-600">Don't have an account? <a href="/Register" class="font-medium text-[#1e3a5f] hover:text-[#f59e0b]">Register here</a></p>
            </div>
        </div>
    </div>
</div>

